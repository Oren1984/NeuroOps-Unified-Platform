# ============================================================
# NeuroOps Unified Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================
# Usage:
#   cp .env.example .env
#   # Edit .env with your real secrets — never commit .env to git
# ============================================================

# --- Platform ---
PLATFORM_ENV=production
PLATFORM_NAME=NeuroOps Unified Platform
PLATFORM_VERSION=2.0.0

# --- Platform Auth (Phase 2 — lightweight internal auth layer) ---
# Change these before any non-local deployment
PLATFORM_USER=admin
PLATFORM_PASSWORD=neuroops2024
PLATFORM_SECRET=neuroops-platform-secret-change-in-production
TOKEN_EXPIRE_HOURS=8

# --- PostgreSQL ---
POSTGRES_USER=neuroops
POSTGRES_PASSWORD=neuroops_dev_2024
POSTGRES_DB=neuroops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Set to empty string to disable external postgres port exposure in production
POSTGRES_EXPOSE_PORT=5432

# --- LLM / AI Providers (optional — services fall back to demo/rule-based mode) ---
# Options: demo | rule_based | openai | anthropic | ollama
LLM_PROVIDER=demo
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Career Agent ---
GMAIL_ENABLED=false
GMAIL_MODE=mock
ENABLE_FUZZY_DEDUP=true
ENABLE_SEMANTIC_SCORING=false

# --- Insight Engine ---
N8N_ENABLED=false
N8N_WEBHOOK_URL=http://n8n:5678/webhook/ai-bi-summary

# --- Warehouse Copilot ---
VECTOR_DB=chroma
EMBEDDING_PROVIDER=local

# --- Frontend ---
VITE_API_BASE=/api
VITE_EMBED_BASE=/embed

# --- Ports (for reference — mapped in docker-compose) ---
# Nginx (public):                80, 443
# Frontend (Nginx static):       80  (internal, via nginx upstream)
# Frontend (Vite dev server):    5173 (dev mode only)
# Gateway API:                   8000 (internal), 8000 (external)
# Autopilot API:                 8001 (external → internal :8000)
# Control Room API:              8002 (external → internal :8000)
# Live Control API:              8003 (external → internal :8000)
# Incident Replay API:           8004 (external → internal :8000)
# Warehouse API:                 8007 (external → internal :8000)
# Career Agent Streamlit:        8511 (external → internal :8501)
# Insight Engine Streamlit:      8512 (external → internal :8501)
# Warehouse Copilot Streamlit:   8513 (external → internal :8501)
# PostgreSQL:                    5432 (external)
# n8n (optional, --profile n8n): 5678 (external)
