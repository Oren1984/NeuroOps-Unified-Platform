# ============================================================
# NeuroOps Unified Platform — root .gitignore
# ============================================================

# Environment secrets — NEVER commit
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend
node_modules/
apps/unified-frontend/dist/
apps/unified-frontend/.vite/
*.tsbuildinfo

# Docker / compose runtime
docker-compose.override.yml

# Databases and data files
*.sqlite
*.db
*.sqlite3

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary / build artifacts
*.tmp
*.bak
*.orig
tmp/
temp/
