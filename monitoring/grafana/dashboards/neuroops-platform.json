{
  "title": "NeuroOps Unified Platform",
  "uid": "neuroops-main",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["neuroops"],
  "panels": [
    {
      "id": 1,
      "title": "Platform Health Score",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 40 },
              { "color": "green",  "value": 70 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_platform_health_score",
          "legendFormat": "Platform Health"
        }
      ]
    },
    {
      "id": 2,
      "title": "Services Online",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_platform_services_healthy",
          "legendFormat": "Healthy"
        }
      ]
    },
    {
      "id": 3,
      "title": "Services Offline",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_platform_services_offline",
          "legendFormat": "Offline"
        }
      ]
    },
    {
      "id": 8,
      "title": "Events in DB",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50000 },
              { "color": "red",    "value": 200000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_platform_events_total",
          "legendFormat": "Events in DB"
        }
      ]
    },
    {
      "id": 9,
      "title": "Events Retention (days)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_events_retention_days",
          "legendFormat": "Retention window"
        }
      ]
    },
    {
      "id": 4,
      "title": "Platform Uptime",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_platform_uptime_seconds",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "id": 5,
      "title": "Service Health Scores",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_service_health_score",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Service Response Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_service_response_ms",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Service Status (1=healthy, 0.5=degraded, 0=offline)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "custom": { "lineWidth": 1.5 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "neuroops_service_status",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
